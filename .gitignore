# =============================================================================
# .gitignore for EE2C2_FPGA_Lab
# Keep the repo to source only: RTL, testbenches, constraints, scripts, board
# files, and the lab handout. Everything regenerable or oversized stays out.
# =============================================================================

# --- Vivado project build outputs (regenerated by the .tcl scripts) ----------
/build/
build_aup_zu3/
build_pwm_dac/
pwm_dac/build_pwm_dac/
pwm_dac/build_pwm_project/
pwm_dac/build_pwm_dac_solution/
rainbow/build_rainbow/
*.jou
*.log
*.str
*.dcp
*.bit
!/prebuilt_bitstreams/
!/prebuilt_bitstreams/*.bit
*.ltx
*.pb
*.rpt
*.wdb
.Xil/
.cache/
.ip_user_files/
hd_visual/
usage_statistics_webtalk.*
webtalk*.jou
webtalk*.log
hs_err_pid*.log

# --- Vivado / xsim simulation artifacts --------------------------------------
xsim.dir/
*.vcd
*.saif
xvhdl.pb
xvlog.pb
xelab.pb

# --- Instructor-only solution / deferred labs --------------------------------
pwm_dac/solutions/
pwm_dac/scripts/*solution*.tcl
xadc_voltage_monitor/
lab_handout/report_template_ta_answers.*

# --- LaTeX build intermediates (handout / report / TA key) -------------------
*.aux
*.lof
*.lot
*.toc
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg
*.nav
*.snm
*.vrb
*.glo
*.gls
*.glg
*.acn
*.acr
*.alg
*.ist
*.idx
*.ilg
*.ind

# --- Misc archives / dumps ---------------------------------------------------
*.zip
*.debug

# --- Orphaned figures from an unrelated LTSpice / CMOS lab --------------------
# These ~16 MB of images are NOT referenced by the FPGA handout. They are kept
# out of the repo to avoid uploading unnecessary big files. The handout's own
# screenshots live in lab_handout/Figures/screenshots/ and ARE tracked.
lab_handout/Figures/*.png
lab_handout/figures.pptx

# --- Local backups -----------------------------------------------------------
lab_handout/_original_backup/
*.orig
*.bak

# --- Editor / OS / tooling ---------------------------------------------------
.vscode/
*.swp
*~
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.claude/settings.local.json
